// ══════════════════════════════════════════════════════════════
// 34. EXECUTION GUIDELINE (Important rules — admin managed)
// ══════════════════════════════════════════════════════════════

model ExecutionGuideline {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("execution_guidelines")
}

// ══════════════════════════════════════════════════════════════
// 35. ESSENTIAL CONTENT (Health Foundation & Optimization)
// ══════════════════════════════════════════════════════════════

model EssentialContent {
  id          String   @id @default(cuid())
  title       String
  description String?
  content     String // rich text/markdown
  imageUrl    String?
  finalMessage String?
  category    String? // "Health Foundation"
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("essential_contents")
}

// ══════════════════════════════════════════════════════════════
// 36. MEDIA ASSET (Global media library — admin managed)
// ══════════════════════════════════════════════════════════════

model MediaAsset {
  id         String    @id @default(cuid())
  url        String    @unique
  type       MediaType
  fileName   String
  fileSize   Int? // bytes
  mimeType   String?
  width      Int?
  height     Int?
  altText    String?
  uploadedBy String? // admin userId
  isPublic   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@index([type])
  @@map("media_assets")
}

// ══════════════════════════════════════════════════════════════
// 37. NOTIFICATION
// ══════════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json? // extra payload
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ══════════════════════════════════════════════════════════════
// 38. PUSH TOKEN (FCM / APNs device tokens)
// ══════════════════════════════════════════════════════════════

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String // "ios" | "android" | "web"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

// ══════════════════════════════════════════════════════════════
// 39. USER FAVORITE EXERCISE
// ══════════════════════════════════════════════════════════════

model UserFavoriteExercise {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@map("user_favorite_exercises")
}

// ══════════════════════════════════════════════════════════════
// 40. ADMIN ACTIVITY LOG (Audit trail for admin actions)
// ══════════════════════════════════════════════════════════════

model AdminActivityLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String // "CREATE_EXERCISE", "PUBLISH_PROGRAM", etc.
  targetType  String? // "Exercise", "Program", etc.
  targetId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_activity_logs")
}

// ══════════════════════════════════════════════════════════════
// 41. APP CONFIG (Feature flags, global settings)
// ══════════════════════════════════════════════════════════════

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string") // "string" | "boolean" | "number" | "json"
  group     String? // "premium", "gym", "notifications"
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("app_configs")
}

// ══════════════════════════════════════════════════════════════
// NEW ENUMS — Admin Panel
// ══════════════════════════════════════════════════════════════

enum ExerciseTabType {
  MAIN_EXERCISE
  BFR_EXERCISE
  ABS_EXERCISE
}

enum BFRContentCategory {
  SAFETY_DISCLAIMER
  BFR_SESSION
  RESEARCH_AND_EDUCATION
}

enum BFRSessionCategory {
  HYPERTROPHY
  STRENGTH
  ENDURANCE
  RECOVERY
}

enum BFRBodyType {
  UPPER
  LOWER
  FULL_BODY
}

enum ResearchCategory {
  BASIC
  ADVANCED
  DETAIL
}

enum NotificationTemplateCategory {
  ENGAGEMENT
  MOTIVATION
  MARKETING
}

enum NotificationAudience {
  ALL_USERS
  PREMIUM_USERS
  FREE_USERS
  TRIAL_USERS
  COACHES
  COACHED_CLIENTS
}

enum PremiumPlanBillingPeriod {
  MONTHLY
  ANNUAL
}

enum HomePageContentType {
  PROGRAM // links to a program
  BANNER // custom banner/image card
  ANNOUNCEMENT // text announcement
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum UserActivityType {
  UPGRADED_TO_PREMIUM
  ENROLLED_IN_PROGRAM
  NEW_REGISTRATION
  COMPLETED_WORKOUT
  COMPLETED_PROGRAM
  COACH_JOINED
  SUBSCRIPTION_CANCELLED
  SUBSCRIPTION_EXPIRED
  LOGIN_FAILED
}

// ══════════════════════════════════════════════════════════════
// 42. PROGRAM DAY EXERCISE SET (admin-defined per-set config)
//     Replaces the flat sets/reps on ProgramDayExercise
//     — supports the "Add Exercise" modal with set rows
// ══════════════════════════════════════════════════════════════

model ProgramDayExerciseSet {
  id                   String  @id @default(cuid())
  programDayExerciseId String
  setNumber            Int // 1, 2, 3 …
  reps                 String // "05", "12", "AMRAP", "10-12"
  restSeconds          Int // 60, 90, 120 …
  notes                String?

  programDayExercise ProgramDayExercise @relation(fields: [programDayExerciseId], references: [id], onDelete: Cascade)

  @@index([programDayExerciseId])
  @@map("program_day_exercise_sets")
}

// ══════════════════════════════════════════════════════════════
// 43. EXERCISE MEDIA (image, video, animation per exercise)
//     Shown in admin "Add Exercise" modal
// ══════════════════════════════════════════════════════════════

model ExerciseMedia {
  id         String    @id @default(cuid())
  exerciseId String
  type       MediaType // IMAGE | VIDEO | GIF
  url        String
  label      String? // "Exercise Image", "Exercise Animation"
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("exercise_media")
}

// ══════════════════════════════════════════════════════════════
// 44. HOME PAGE CONTENT (admin-ordered program/banner cards)
//     Content Management → Home Page Content tab
// ══════════════════════════════════════════════════════════════

model HomePageContent {
  id          String              @id @default(cuid())
  type        HomePageContentType @default(PROGRAM)
  programId   String? // if type = PROGRAM
  title       String? // custom title override
  description String?
  imageUrl    String?
  position    Int // ordering position (1, 2, 3 …)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  program Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([position])
  @@map("home_page_contents")
}

// ══════════════════════════════════════════════════════════════
// 45. PREMIUM WEEK LOCK CONFIG
//     Content Management → Premium Lock Library tab
//     Admin controls which weeks are free vs premium per program
// ══════════════════════════════════════════════════════════════

model PremiumWeekLockConfig {
  id               String   @id @default(cuid())
  programId        String
  weekNumber       Int
  isPremiumLock    Boolean  @default(false) // true = premium required
  updatedAt        DateTime @updatedAt
  updatedByAdminId String?

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, weekNumber])
  @@index([programId])
  @@map("premium_week_lock_configs")
}

// ══════════════════════════════════════════════════════════════
// 46. EXECUTION NOTE
//     Content Management → Execution Notes tab
//     Rules/guidelines shown to users (e.g. "Workout Duration Rule")
// ══════════════════════════════════════════════════════════════

model ExecutionNote {
  id           String   @id @default(cuid())
  title        String // "Workout Duration Rule"
  notes        String[] @default([]) // individual bullet notes
  finalMessage String? // bottom summary paragraph
  position     Int      @default(0) // ordering
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([position])
  @@map("execution_notes")
}

// ══════════════════════════════════════════════════════════════
// 47. BFR CONTENT — Safety Disclaimer, BFR Sessions, Research
//     Content Management → BFR Sessions Guidelines tab
// ══════════════════════════════════════════════════════════════

model BFRContent {
  id               String             @id @default(cuid())
  category         BFRContentCategory // SAFETY_DISCLAIMER | BFR_SESSION | RESEARCH_AND_EDUCATION
  title            String
  shortDescription String?
  richContent      String? // HTML/Markdown rich text (safety info section)
  finalMessage     String?

  // BFR_SESSION specific fields
  sessionCategory BFRSessionCategory? // Hypertrophy / Strength etc.
  bodyType        BFRBodyType? // Upper / Lower / Full Body
  durationMinutes Int? // e.g. 20
  exerciseCount   Int? // e.g. 4

  // RESEARCH_AND_EDUCATION specific fields
  researchCategory ResearchCategory? // Basic / Advanced / Detail

  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([sessionCategory])
  @@map("bfr_contents")
}

// ══════════════════════════════════════════════════════════════
// 48. HEALTH MARKER GROUP
//     Essential Management → Health Checks & Clinics
//     Admin manages named groups like "Hormonal Balance" with marker items
// ══════════════════════════════════════════════════════════════

model HealthMarkerGroup {
  id          String              @id @default(cuid())
  category    HealthCheckCategory
  name        String // "Hormonal Balance"
  description String?
  sortOrder   Int                 @default(0)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  markers HealthMarker[]

  @@index([category])
  @@map("health_marker_groups")
}

model HealthMarker {
  id        String @id @default(cuid())
  groupId   String
  name      String // "Testosterone levels (free and total)"
  sortOrder Int    @default(0)

  group HealthMarkerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("health_markers")
}

// ══════════════════════════════════════════════════════════════
// 49. SUPPLEMENT PRODUCT (admin-managed affiliate product catalog)
//     Essential Management → Supplement tab
//     Replaces / extends AffiliateProduct with admin CRUD UI fields
// ══════════════════════════════════════════════════════════════

model SupplementProduct {
  id              String             @id @default(cuid())
  name            String // "Creatine HCL"
  category        SupplementCategory // Foundation / Performance / Recovery / Optional
  price           Float
  currency        String             @default("USD")
  vendorName      String? // "OptimumNutrition"
  purchasePageUrl String // affiliate purchase URL
  benefits        String[]           @default([]) // ["No bloating", "Micronized", "Third-party tested"]
  imageUrl        String?
  inStock         Boolean            @default(true)
  isActive        Boolean            @default(true)
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([category])
  @@index([inStock])
  @@map("supplement_products")
}

// ══════════════════════════════════════════════════════════════
// 50. SUBSCRIPTION PLAN CONFIG
//     Premium Features → Subscription Plans tab
//     Admin can edit plan names, prices, features, billing period
// ══════════════════════════════════════════════════════════════

model SubscriptionPlanConfig {
  id             String                    @id @default(cuid())
  name           String // "Monthly Premium", "Yearly Premium", "Free"
  plan           SubscriptionPlan          @unique
  billingPeriod  PremiumPlanBillingPeriod?
  priceUSD       Float                     @default(0)
  isPopular      Boolean                   @default(false)
  savingsPercent Int? // e.g. 17 (for "Save 17%")
  features       String[]                  @default([]) // feature bullet strings
  stripePriceId  String?
  isActive       Boolean                   @default(true)
  updatedAt      DateTime                  @updatedAt
  updatedBy      String?

  @@map("subscription_plan_configs")
}

// ══════════════════════════════════════════════════════════════
// 51. PAYMENT TRANSACTION
//     Premium Features → Payment Management tab
//     Full payment ledger for all transactions
// ══════════════════════════════════════════════════════════════

model PaymentTransaction {
  id              String           @id @default(cuid())
  userId          String
  stripePaymentId String?          @unique
  stripeInvoiceId String?          @unique
  plan            SubscriptionPlan
  amount          Float
  currency        String           @default("USD")
  status          PaymentStatus    @default(PENDING)
  description     String?
  refundedAt      DateTime?
  refundAmount    Float?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_transactions")
}

// ══════════════════════════════════════════════════════════════
// 52. PUSH NOTIFICATION TEMPLATE
//     Settings → Push Notification Templates
//     Admin enables/disables pre-defined templates + sends custom blasts
// ══════════════════════════════════════════════════════════════

model PushNotificationTemplate {
  id            String                       @id @default(cuid())
  name          String // "Workout Reminder"
  category      NotificationTemplateCategory // ENGAGEMENT | MOTIVATION | MARKETING
  titleTemplate String // "Time to train, {name}!"
  bodyTemplate  String // "Your workout is ready."
  isEnabled     Boolean                      @default(false)
  // scheduling
  scheduledCron String? // cron expression for automated sends
  updatedAt     DateTime                     @updatedAt
  updatedBy     String?

  blasts NotificationBlast[]

  @@map("push_notification_templates")
}

// ══════════════════════════════════════════════════════════════
// 53. NOTIFICATION BLAST (custom or template-based sends)
//     Settings → Send Custom Notification
// ══════════════════════════════════════════════════════════════

model NotificationBlast {
  id            String               @id @default(cuid())
  templateId    String? // null = custom blast
  audience      NotificationAudience @default(ALL_USERS)
  title         String
  message       String
  sentByAdminId String
  scheduledAt   DateTime? // null = send now
  sentAt        DateTime?
  totalSent     Int                  @default(0)
  totalFailed   Int                  @default(0)
  createdAt     DateTime             @default(now())

  template PushNotificationTemplate? @relation(fields: [templateId], references: [id])

  @@index([sentByAdminId])
  @@index([scheduledAt])
  @@map("notification_blasts")
}

// ══════════════════════════════════════════════════════════════
// 54. PLATFORM ANALYTICS SNAPSHOT
//     Dashboard charts — stored daily snapshots for fast queries
// ══════════════════════════════════════════════════════════════

model PlatformAnalyticsSnapshot {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  totalUsers        Int      @default(0)
  premiumUsers      Int      @default(0)
  freeUsers         Int      @default(0)
  trialUsers        Int      @default(0)
  expiredUsers      Int      @default(0)
  activeEnrollments Int      @default(0)
  totalCoaches      Int      @default(0)
  coachedClients    Int      @default(0)
  monthlyRevenue    Float    @default(0)
  newUsersToday     Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([date])
  @@map("platform_analytics_snapshots")
}

// ══════════════════════════════════════════════════════════════
// 55. USER ACTIVITY LOG
//     Dashboard → Recent Activity feed
//     Tracks key user events for admin visibility
// ══════════════════════════════════════════════════════════════

model UserActivityLog {
  id        String           @id @default(cuid())
  userId    String
  type      UserActivityType
  meta      Json? // e.g. { programName: "Monster Mass Builder" }
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("user_activity_logs")
}

// ══════════════════════════════════════════════════════════════
// 56. PROGRAM ANALYTICS
//     Program Management → Program Analytics tab
//     Per-program enrollment + completion metrics
// ══════════════════════════════════════════════════════════════

model ProgramAnalytics {
  id                String   @id @default(cuid())
  programId         String   @unique
  totalEnrollments  Int      @default(0)
  activeEnrollments Int      @default(0)
  completedCount    Int      @default(0)
  completionRate    Float    @default(0) // 0-100 %
  avgWeeksCompleted Float    @default(0)
  updatedAt         DateTime @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_analytics")
}
