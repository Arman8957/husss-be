// ══════════════════════════════════════════════════════════════
// 33. GYM (Find Gym feature — future)
// ══════════════════════════════════════════════════════════════

model Gym {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String
  city        String
  country     String
  phone       String?
  email       String?
  website     String?
  bookingUrl  String?
